# Copy this file to `.env` and fill in your real values.
# Expo automatically exposes any var prefixed EXPO_PUBLIC_ to client code
# via process.env — no extra config needed (SDK 49+).
#
# ⚠️ .env is in .gitignore — never commit real secrets. Client-side values
# here are still bundled into the app binary and are NOT truly secret
# (anyone can decompile the app and read them), which is normal for
# Firebase web config and OAuth *client* IDs. Never put server-side
# secrets (Firebase Admin SDK keys, server API secrets) in EXPO_PUBLIC_ vars.

# --- Firebase (Web SDK config — safe for client bundling) ---
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=ludo-royale.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=ludo-royale
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=ludo-royale.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890abcdef

# --- Google Sign-In OAuth Client IDs (from Google Cloud Console) ---
# You need a separate client ID per platform target.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=123456789012-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=123456789012-yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=123456789012-zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzz.apps.googleusercontent.com

# --- Apple Sign-In ---
# Apple Sign-In itself needs no client ID on iOS (handled by
# expo-apple-authentication + your app's bundle ID/entitlement), but if
# you support "Sign in with Apple" on the web/Android via Firebase's
# OAuth redirect flow, you'll need your Services ID here.
EXPO_PUBLIC_APPLE_SERVICES_ID=com.diviaix.ludoroyale.signin

# --- Multiplayer server ---
# Local dev default. Override per environment (see README "Server URLs").
EXPO_PUBLIC_SERVER_URL=http://localhost:3001
EXPO_PUBLIC_SERVER_URL_PROD=https://your-deployed-server.example.com

# --- Misc ---
EXPO_PUBLIC_ENV=development
